---
import { getLocaleFromUrl, getTranslations } from "../i18n/utils";

const locale = getLocaleFromUrl(Astro.url);
const t = getTranslations(locale);
---

<section id="about" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-[1fr_1.2fr] gap-16 items-start">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-accent"><span class="font-mono mr-2">//</span>{t.about.title}</h2>
        <p class="text-lg text-text-secondary leading-relaxed">
          {t.about.description}
        </p>
      </div>

      <div class="space-y-8 border-l border-border pl-8">
        {t.about.values.map((value, i) => (
          <div class="group">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="text-accent font-mono text-sm">0{i + 1}</span>
              <h3 class="text-lg font-semibold group-hover:text-accent transition-colors">
                {value.title}
              </h3>
            </div>
            <p class="text-sm text-text-secondary leading-relaxed ml-8">
              {value.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
