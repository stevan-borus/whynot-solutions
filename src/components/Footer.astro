---
import { getLocaleFromUrl, getTranslations } from "../i18n/utils";

const locale = getLocaleFromUrl(Astro.url);
const t = getTranslations(locale);
const year = new Date().getFullYear();
const prefix = locale === "sr" ? "" : "/en";
const home = locale === "sr" ? "/" : "/en/";
---

<footer class="border-t border-border py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-[1fr_auto_auto] gap-12 md:gap-24 mb-12">
      <!-- Brand -->
      <div>
        <div class="flex items-baseline gap-0 mb-4">
          <span class="text-lg font-extrabold text-text-primary tracking-tight">WhyNot</span>
          <span class="text-lg font-mono text-accent">_</span>
          <span class="text-[0.5rem] font-mono uppercase tracking-[0.3em] text-text-secondary ml-2">Solutions</span>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed">
          {t.footer.tagline}
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-sm font-semibold mb-4">{t.footer.linksTitle}</h4>
        <div class="flex flex-col gap-2">
          <a href={`${home}#about`} class="text-sm text-text-secondary hover:text-accent transition-colors">{t.nav.about}</a>
          <a href={`${home}#services`} class="text-sm text-text-secondary hover:text-accent transition-colors">{t.nav.services}</a>
          <a href={`${home}#contact`} class="text-sm text-text-secondary hover:text-accent transition-colors">{t.nav.contact}</a>
        </div>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold mb-4">{t.footer.legalTitle}</h4>
        <div class="flex flex-col gap-2">
          <a href={`${prefix}/privacy/`} class="text-sm text-text-secondary hover:text-accent transition-colors">{t.footer.privacy}</a>
          <a href={`${prefix}/terms/`} class="text-sm text-text-secondary hover:text-accent transition-colors">{t.footer.terms}</a>
        </div>
      </div>
    </div>

    <div class="border-t border-border pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-secondary">
        &copy; {year} {t.footer.copyright}
      </p>
      <a href={`mailto:${t.footer.email}`} class="text-xs text-text-secondary hover:text-accent transition-colors">
        {t.footer.email}
      </a>
      <p class="text-xs text-text-secondary">
        {t.footer.address}
      </p>
    </div>
  </div>
</footer>
